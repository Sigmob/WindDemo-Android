<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/cfg_btn_secondary_bg"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/ad_info_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true">

        <!-- 原生广告的小图 -->
        <ImageView
            android:id="@+id/img_logo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:layout_margin="16dp"
            tools:src="@android:color/darker_gray" />

        <!-- 原生广告的标题 -->
        <TextView
            android:id="@+id/text_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignTop="@id/img_logo"
            android:layout_toStartOf="@id/iv_dislike"
            android:layout_toEndOf="@id/img_logo"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:singleLine="true"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="广告 Tittle" />

        <!-- 原生广告的描述 -->
        <TextView
            android:id="@+id/text_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/text_title"
            android:layout_alignBottom="@id/img_logo"
            android:layout_marginEnd="8dp"
            android:layout_toEndOf="@id/img_logo"
            android:ellipsize="marquee"
            android:gravity="center_vertical"
            android:singleLine="true"
            android:textColor="#AA000000"
            android:textSize="12sp"
            tools:text="一段广告描述一段广告描述一段广告描述一段广告描述描述一段广告描述" />

        <!-- disLike 的小图 -->
        <ImageView
            android:id="@+id/iv_dislike"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_alignParentEnd="true"
            android:layout_margin="16dp"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/tt_dislike" />

    </RelativeLayout>

    <LinearLayout
        android:id="@+id/video_btn_container"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_below="@id/ad_info_container"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal"
        tools:visibility="visible">

        <Button
            android:id="@+id/btn_play"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/cfg_btn_secondary_bg"
            android:text="播放"
            android:textColor="#080"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_pause"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/cfg_btn_secondary_bg"
            android:text="暂停"
            android:textColor="#00f"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_stop"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/cfg_btn_secondary_bg"
            android:text="停止"
            android:textColor="#f00"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_voice"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/cfg_btn_secondary_bg"
            android:text="有声"
            android:textColor="#f00"
            android:textSize="12sp" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/custom_container"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_below="@id/video_btn_container"
        android:layout_centerHorizontal="true"
        android:layout_marginHorizontal="16dp">

        <!-- 原生广告的视频组件 -->
        <FrameLayout
            android:id="@+id/media_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:background="@android:color/black" />

        <!-- 原生广告的大图 -->
        <ImageView
            android:id="@+id/img_poster"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center_horizontal"
            android:scaleType="centerCrop" />

        <!-- 原生三小图 -->
        <LinearLayout
            android:id="@+id/native_3img_ad_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <ImageView
                android:id="@+id/img_1"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="3dp"
                android:layout_weight="1"
                android:adjustViewBounds="true"
                android:scaleType="fitXY" />

            <ImageView
                android:id="@+id/img_2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="3dp"
                android:layout_weight="1"
                android:adjustViewBounds="true"
                android:scaleType="fitXY" />

            <ImageView
                android:id="@+id/img_3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="3dp"
                android:layout_weight="1"
                android:adjustViewBounds="true"
                android:scaleType="fitXY" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|bottom"
            android:background="@drawable/bg_fillet_4dp_transparent"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="4dp">

            <!-- 原生广告的 logo -->
            <ImageView
                android:id="@+id/channel_ad_logo"
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:scaleType="centerInside"
                android:src="@drawable/sig_logo"
                android:visibility="visible" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="广告"
                android:textColor="@android:color/white"
                android:textSize="8sp" />

        </LinearLayout>

    </FrameLayout>

    <!-- 视频播放进度区域：百分比文字 + 进度条 -->
    <LinearLayout
        android:id="@+id/video_progress_container"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:layout_below="@id/custom_container"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone"
        tools:visibility="visible">

        <ProgressBar
            android:id="@+id/video_progress_bar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="0"
            android:progressBackgroundTint="#E0E0E0"
            android:progressTint="#FF5722" />

        <TextView
            android:id="@+id/tv_video_progress_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:gravity="end"
            android:minWidth="32dp"
            android:textColor="#FF5722"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="100%" />

    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_below="@id/video_progress_container">

        <!-- 原生广告的点击按钮 -->
        <Button
            android:id="@+id/btn_cta"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_centerInParent="true"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/btn_bg_creative"
            android:gravity="center"
            android:text="查看详情"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

    </RelativeLayout>

</RelativeLayout>